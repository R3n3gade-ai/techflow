graph TD
    %% Styling
    classDef external fill:#f9f9f9,stroke:#333,stroke-width:2px;
    classDef data fill:#e3f2fd,stroke:#0d47a1,stroke-width:2px;
    classDef brain fill:#e8f5e9,stroke:#1565c0,stroke-width:2px;
    classDef defense fill:#fff3e0,stroke:#2e7d32,stroke-width:2px;
    classDef offense fill:#fce4ec,stroke:#ef6c00,stroke-width:2px;
    classDef execution fill:#ffebee,stroke:#c2185b,stroke-width:2px;
    classDef broker fill:#fafafa,stroke:#424242,stroke-width:2px;
    classDef audit fill:#f3e5f5,stroke:#c62828,stroke-width:2px;

    %% External Inputs
    subgraph L1 [Layer 1: The Senses Data Ingestion]
        FRED[Federal Reserve Data]
        CRYPTO[Crypto Microstructure]
        IBKR_DATA[IBKR Live Prices]
        NEWS[Market News & SEC Filings]
    end
    class FRED,CRYPTO,IBKR_DATA,NEWS external

    %% The Brain
    subgraph L2 [Layer 2: The Macro Compass]
        RPE[RPE: Anticipatory Regime Probabilities]
        MACRO[Macro Compass: Current Regime Score]
        ARAS_SUB[6 Systemic Risk Sub-Modules]
    end
    class RPE,MACRO,ARAS_SUB data

    subgraph L3 [Layer 3: The Risk Coordinator]
        ARAS[ARAS: Sets Equity Ceiling]
        PDS[PDS: High-Water Mark Override]
        FEM[FEM: Concentration Check]
        KEVLAR[Kevlar: Hard Position Limits]
    end
    class ARAS,PDS,FEM,KEVLAR brain

    %% The Analysts
    subgraph INTELLIGENCE [Thesis Integrity Checkers]
        CDM[CDM: Event Propagation]
        TDC[TDC: AI Thesis Review]
    end
    class CDM,TDC data

    %% The Core Strategies
    subgraph L4 [Layer 4: The Master Engine]
        MICS[MICS: Mathematical Conviction Sizing]
        MASTER[Master Engine: Target Weights]
        CDF[CDF: Position Decay Penalty]
        AUP[AUP: Asymmetric Upside Protocol]
        ARES[ARES: Phased Re-Entry]
    end
    class MICS,MASTER,CDF,AUP,ARES offense

    %% The Shields
    subgraph DEFENSE [The Armor]
        CAM[CAM: Options Coverage Math]
        PTRH[PTRH: Live QQQ Put Hunting]
        DSHP[DSHP: Gold/Futures Harvest]
    end
    class CAM,PTRH,DSHP defense

    %% The Nerves
    subgraph L5 [Layer 5: The Nerves & Muscles]
        ORDER_GEN[Trade Order Generator]
        LAEP[LAEP: Liquidity Adjusted Execution]
        CB[Circuit Breaker: Market Panic Halt]
        QUEUE[Persistent Confirmation Queue]
    end
    class ORDER_GEN,LAEP,CB,QUEUE execution

    %% Action
    subgraph L6 [Layer 6: The Hands]
        BROKER[IBKR Paper Trading Account]
    end
    class BROKER broker

    %% Memory
    subgraph L7 [Layer 7: The Memory]
        AUDIT[Immutable Correlation Audit Log]
        MONITOR[Daily Institutional PDF Briefing]
    end
    class AUDIT,MONITOR audit

    %% Connections
    L1 --> L2
    NEWS --> CDM
    CDM --> TDC
    TDC --> MICS
    
    L2 --> L3
    L3 --> MASTER
    L3 --> CAM
    
    MICS --> MASTER
    CDF --> MASTER
    AUP --> MASTER
    ARES --> MASTER
    
    CAM --> PTRH
    
    MASTER --> ORDER_GEN
    PTRH --> ORDER_GEN
    DSHP --> ORDER_GEN
    
    ORDER_GEN --> CB
    CB --> LAEP
    LAEP --> QUEUE
    QUEUE --> BROKER
    
    BROKER --> AUDIT
    QUEUE --> AUDIT
    AUDIT --> MONITOR
